{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020", "DOM"],
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "allowJs": false,
    "skipLibCheck": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@pages/*": ["src/pages/*"],
      "@utils/*": ["src/core/utils/*"],
      "@api/*": ["src/api/*"]
    },
    "types": ["node", "@playwright/test"],
    "strict": true
  },
  "include": [
    "src",
    "tests",
    "playwright.config.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}